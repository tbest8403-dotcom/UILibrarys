local TextRegistry = {}
local CurrentTextScale = 1
local TextClasses = {
    TextLabel = true,
    TextButton = true,
    TextBox = true
}

local function ApplyResponsiveTextScale(Scale)
    CurrentTextScale = math.clamp(Scale or 1, 0.82, 1.16)

    for Index = #TextRegistry, 1, -1 do
        local Data = TextRegistry[Index]
        local Object = Data.Object

        if Object and Object.Parent then
            Object.TextSize = math.max(9, math.floor((Data.BaseSize * CurrentTextScale) + 0.5))
        else
            table.remove(TextRegistry, Index)
        end
    end
end

local function RegisterResponsiveText(Object, BaseSize)
    if not Object or not BaseSize then
        return
    end

    table.insert(TextRegistry, {
        Object = Object,
        BaseSize = BaseSize
    })

    Object.TextSize = math.max(9, math.floor((BaseSize * CurrentTextScale) + 0.5))
end

local function Tween(Object, Time, Properties, Style, Direction)
    local Info = TweenInfo.new(
        Time or 0.2,
        Style or Enum.EasingStyle.Quad,
        Direction or Enum.EasingDirection.Out
    )

    local T = TweenService:Create(Object, Info, Properties)
    T:Play()
    return T
end

local function Create(ClassName, Properties, Children)
    local Object = Instance.new(ClassName)

    for Property, Value in pairs(Properties or {}) do
        Object[Property] = Value
    end

    if TextClasses[ClassName] and Properties and typeof(Properties.TextSize) == "number" then
        RegisterResponsiveText(Object, Properties.TextSize)
    end

    for _, Child in ipairs(Children or {}) do
        Child.Parent = Object
    end

    return Object
end

