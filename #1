                })

                local OptionsHolder = Create("Frame", {
                    Position = UDim2.fromOffset(8, 42),
                    Size = UDim2.new(1, -16, 0, 0),
                    BackgroundTransparency = 1,
                    ClipsDescendants = true,
                    Parent = Control
                })

                local OptionsLayout = List(OptionsHolder, Enum.FillDirection.Vertical, 5)

                local Object = {}

                local function Resize()
                    local TargetHeight = Open and (46 + (#OptionsList * 31)) or 42

                    Tween(Control, 0.18, {
                        Size = UDim2.new(1, 0, 0, TargetHeight)
                    })

                    Tween(OptionsHolder, 0.18, {
                        Size = UDim2.new(1, -16, 0, Open and (#OptionsList * 31) or 0)
                    })

                end

                local function Set(Value, NoCallback)
                    Selected = Value
                    ValueLabel.Text = tostring(Value)
                    Window.Flags[Data.Flag or Data.Name or "Dropdown"] = Value

                    if Data.Callback and not NoCallback then
                        task.spawn(function()
                            Data.Callback(Value)
                        end)
                    end
                end

                local function RebuildOptions()
                    for _, Child in ipairs(OptionsHolder:GetChildren()) do
                        if Child:IsA("TextButton") then
                            Child:Destroy()
                        end
                    end

                    for _, Option in ipairs(OptionsList) do
                        local OptionButton = Create("TextButton", {
                            Size = UDim2.new(1, 0, 0, 26),
                            BackgroundColor3 = Theme.Button,
                            BorderSizePixel = 0,
                            Text = tostring(Option),
                            TextColor3 = Theme.Text,
                            TextSize = 12,
                            Font = Enum.Font.Gotham,
                            Parent = OptionsHolder
                        })

                        Corner(OptionButton, 8)
                        Stroke(OptionButton, Theme.Stroke, 1, 0.82)
                        AnimateButton(OptionButton)

                        OptionButton.MouseButton1Click:Connect(function()
                            Set(Option)
                            Open = false
                            Resize()
                        end)
                    end
                end

                Header.MouseButton1Click:Connect(function()
                    Open = not Open
                    Resize()
                end)

                function Object:Set(Value)
                    Set(Value)
                end

                function Object:Get()
                    return Selected
                end

                function Object:Refresh(NewOptions, KeepSelected)
                    OptionsList = NewOptions or {}

                    if not KeepSelected then
                        Selected = OptionsList[1] or "None"
                    end

                    ValueLabel.Text = tostring(Selected)
                    RebuildOptions()
                    Resize()
                end

                RebuildOptions()
                Set(Selected, true)

                return Object
            end

