            function Section:CreateSlider(Data)
                Data = Data or {}

                local Min = Data.Min or 0
                local Max = Data.Max or 100
                local Increment = Data.Increment or 1
                local Value = Data.Default or Min
                local Dragging = false

                local Control = BaseControl(Data.Name or "Slider", 58)

                local Label = Create("TextLabel", {
                    Position = UDim2.fromOffset(10, 4),
                    Size = UDim2.new(1, -80, 0, 22),
                    BackgroundTransparency = 1,
                    Text = tostring(Data.Name or "Slider"),
                    TextColor3 = Theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextSize = 12,
                    Font = Enum.Font.GothamBold,
                    Parent = Control
                })

                local ValueLabel = Create("TextLabel", {
                    AnchorPoint = Vector2.new(1, 0),
                    Position = UDim2.new(1, -10, 0, 4),
                    Size = UDim2.fromOffset(70, 22),
                    BackgroundTransparency = 1,
                    Text = tostring(Value),
                    TextColor3 = Theme.MutedText,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    TextSize = 12,
                    Font = Enum.Font.Gotham,
                    Parent = Control
                })

                local Bar = Create("Frame", {
                    Position = UDim2.fromOffset(10, 35),
                    Size = UDim2.new(1, -20, 0, 8),
                    BackgroundColor3 = Theme.Button,
                    BorderSizePixel = 0,
                    Parent = Control
                })

                Corner(Bar, 4)

                local Fill = Create("Frame", {
                    Size = UDim2.fromScale(0, 1),
                    BackgroundColor3 = Theme.AccentDark,
                    BorderSizePixel = 0,
                    Parent = Bar
                })

                Corner(Fill, 4)

                local Object = {}

                local function RoundToIncrement(Number)
                    return math.floor((Number / Increment) + 0.5) * Increment
                end

                local function Set(NewValue, NoCallback)
                    Value = math.clamp(RoundToIncrement(NewValue), Min, Max)

                    local Percent = 0
                    if Max ~= Min then
                        Percent = (Value - Min) / (Max - Min)
                    end

                    Window.Flags[Data.Flag or Data.Name or "Slider"] = Value
                    ValueLabel.Text = tostring(Value)

                    Tween(Fill, 0.12, {
                        Size = UDim2.fromScale(Percent, 1)
                    })

                    if Data.Callback and not NoCallback then
                        task.spawn(function()
                            Data.Callback(Value)
                        end)
                    end
                end

                local function UpdateFromInput(Input)
                    local Percent = math.clamp((Input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
                    Set(Min + ((Max - Min) * Percent))
                end

                Bar.InputBegan:Connect(function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                        Dragging = true
                        UpdateFromInput(Input)
                    end
                end)

                Bar.InputEnded:Connect(function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                        Dragging = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(Input)
                    if Dragging and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                        UpdateFromInput(Input)
                    end
                end)

                function Object:Set(NewValue)
                    Set(NewValue)
                end

                function Object:Get()
                    return Value
                end

                Set(Value, true)
                return Object
            end

