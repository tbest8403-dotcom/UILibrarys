local function MakeDraggable(Frame, Handle)
    Handle = Handle or Frame

    local Dragging = false
    local DragInput = nil
    local DragStart = nil
    local StartPosition = nil

    local function Update(Input)
        local Delta = Input.Position - DragStart
        Frame.Position = UDim2.new(
            StartPosition.X.Scale,
            StartPosition.X.Offset + Delta.X,
            StartPosition.Y.Scale,
            StartPosition.Y.Offset + Delta.Y
        )
    end

    Handle.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
            Dragging = true
            DragStart = Input.Position
            StartPosition = Frame.Position

            Input.Changed:Connect(function()
                if Input.UserInputState == Enum.UserInputState.End then
                    Dragging = false
                end
            end)
        end
    end)

    Handle.InputChanged:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
            DragInput = Input
        end
    end)

    UserInputService.InputChanged:Connect(function(Input)
        if Input == DragInput and Dragging then
            Update(Input)
        end
    end)
end

local function MakeResizable(Frame, Grip, MinSize, MaxSize)
    local Resizing = false
    local ResizeInput = nil
    local StartMouse = nil
    local StartSize = nil

    MinSize = MinSize or Vector2.new(320, 250)
    MaxSize = MaxSize or Vector2.new(720, 520)

    Grip.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
            Resizing = true
            StartMouse = Input.Position
            StartSize = Frame.AbsoluteSize

            Input.Changed:Connect(function()
                if Input.UserInputState == Enum.UserInputState.End then
                    Resizing = false
                end
            end)
        end
    end)

    Grip.InputChanged:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
            ResizeInput = Input
        end
    end)

    UserInputService.InputChanged:Connect(function(Input)
        if Input == ResizeInput and Resizing then
            local Delta = Input.Position - StartMouse
            local NewWidth = math.clamp(StartSize.X + Delta.X, MinSize.X, MaxSize.X)
            local NewHeight = math.clamp(StartSize.Y + Delta.Y, MinSize.Y, MaxSize.Y)

            Frame.Size = UDim2.fromOffset(NewWidth, NewHeight)
        end
    end)
end

local function AnimateButton(Button)
    Button.AutoButtonColor = false

    Button.MouseEnter:Connect(function()
        Tween(Button, 0.15, {
            BackgroundColor3 = Theme.ButtonHover
        })
    end)

    Button.MouseLeave:Connect(function()
        Tween(Button, 0.15, {
            BackgroundColor3 = Theme.Button
        })
    end)

    Button.MouseButton1Down:Connect(function()
        Tween(Button, 0.08, {
            Size = UDim2.new(Button.Size.X.Scale, Button.Size.X.Offset, Button.Size.Y.Scale, Button.Size.Y.Offset - 2)
        })
    end)

    Button.MouseButton1Up:Connect(function()
        Tween(Button, 0.08, {
            Size = UDim2.new(Button.Size.X.Scale, Button.Size.X.Offset, Button.Size.Y.Scale, Button.Size.Y.Offset + 2)
        })
    end)
end

local function NormalizeKeys(Keys)
    local NewKeys = {}

    if typeof(Keys) == "table" then
        for _, Key in ipairs(Keys) do
            table.insert(NewKeys, tostring(Key))
        end
    elseif typeof(Keys) == "string" then
        table.insert(NewKeys, Keys)
    end

    return NewKeys
end

local function IsValidKey(Text, Keys)
    for _, Key in ipairs(Keys) do
        if Text == Key then
            return true
        end
    end

    return false
end

