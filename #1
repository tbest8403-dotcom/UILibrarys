            Parent = KeyFrame
        })

        Corner(KeyBox, 9)
        Stroke(KeyBox, Theme.Stroke, 1, 0.75)

        local Submit = Create("TextButton", {
            Position = UDim2.fromOffset(14, 123),
            Size = UDim2.new(0.5, -18, 0, 34),
            BackgroundColor3 = Theme.Button,
            BorderSizePixel = 0,
            Text = "Submit",
            TextColor3 = Theme.Text,
            TextSize = 13,
            Font = Enum.Font.GothamBold,
            Parent = KeyFrame
        })

        Corner(Submit, 9)
        Stroke(Submit, Theme.Stroke, 1, 0.75)
        AnimateButton(Submit)

        local GetKey = Create("TextButton", {
            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.new(1, -14, 0, 123),
            Size = UDim2.new(0.5, -18, 0, 34),
            BackgroundColor3 = Theme.Button,
            BorderSizePixel = 0,
            Text = "Get key here > " .. tostring(Discord),
            TextColor3 = Theme.MutedText,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            Parent = KeyFrame
        })

        Corner(GetKey, 9)
        Stroke(GetKey, Theme.Stroke, 1, 0.75)
        AnimateButton(GetKey)

        GetKey.MouseButton1Click:Connect(function()
            local Link = tostring(Discord)

            local Copied = false

            if typeof(setclipboard) == "function" then
                local Success = pcall(function()
                    setclipboard(Link)
                end)

                Copied = Success
            elseif typeof(toclipboard) == "function" then
                local Success = pcall(function()
                    toclipboard(Link)
                end)

                Copied = Success
            end

            if Copied then
                Window:Notify({
                    Title = "Copied",
                    Content = "Discord link copied to clipboard.",
                    Duration = 3
                })
            else
                Window:Notify({
                    Title = "Copy Not Supported",
                    Content = "Your executor/client does not support clipboard copy. Link: " .. Link,
                    Duration = 6
                })
            end
        end)

        local function Unlock()
            Tween(KeyFrame, 0.2, {
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -70, 0, 150)
            })

            task.wait(0.2)
            KeyFrame:Destroy()

            Sidebar.Visible = true
            ContentHolder.Visible = true
            ResizeGrip.Visible = true

            Window:Notify({
                Title = "Unlocked",
                Content = "Key accepted. UI loaded.",
                Duration = 3
            })
        end

        local function WrongKey()
            Window:Notify({
                Title = "Wrong Key",
                Content = "That key is not valid.",
                Duration = 3
            })

            local OriginalPosition = KeyFrame.Position

            for _ = 1, 3 do
                Tween(KeyFrame, 0.05, {
                    Position = OriginalPosition + UDim2.fromOffset(8, 0)
                })
                task.wait(0.05)

                Tween(KeyFrame, 0.05, {
                    Position = OriginalPosition - UDim2.fromOffset(8, 0)
                })
                task.wait(0.05)
            end

            Tween(KeyFrame, 0.05, {
                Position = OriginalPosition
            })
        end

        Submit.MouseButton1Click:Connect(function()
            if #Keys == 0 then
                Unlock()
                return
            end

            if IsValidKey(KeyBox.Text, Keys) then
                Unlock()
            else
                WrongKey()
            end
        end)

        KeyBox.FocusLost:Connect(function(EnterPressed)
            if EnterPressed then
                if #Keys == 0 or IsValidKey(KeyBox.Text, Keys) then
                    Unlock()
                else
                    WrongKey()
                end
            end
        end)
    end

    if KeySystemEnabled then
        ShowKeySystem()
    end

    return Window
end

return Library
